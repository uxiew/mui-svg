{
  "name": "mui-svg",
  "version": "0.1.0",
  "description": "Pure data version of Material Design Icons which can be used in all framework applications.",
  "type": "module",
  "license": "MIT",
  "author": "ver5",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "bun run scripts/generate.ts",
    "clean": "rm -rf dist src/icons",
    "build": "bun run clean && bun run generate && tsc -p tsconfig.build.json",
    "playground": "bun run --hot playground/index.ts",
    "playground:build": "bun run scripts/build-playground.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "icons",
    "material-icons",
    "material-design",
    "mdi",
    "svg",
    "svg-path",
    "mui",
    "tree-shakable",
    "data-only"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxiew/mui-svg.git"
  },
  "homepage": "https://github.com/uxiew/mui-svg#readme",
  "bugs": {
    "url": "https://github.com/uxiew/mui-svg/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "muiIconsMaterialVersion": "9.0.0",
  "devDependencies": {
    "@mui/icons-material": "^9.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "flexsearch": "^0.8.212",
    "react": "^19.0.0",
    "typescript": "^6.0.3"
  }
}
